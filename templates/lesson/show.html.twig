{% extends 'base.html.twig' %}

{% block title %}{{ lesson.name }}{% endblock %}

{% block body %}
    <h1 class="text-break mb-4">{{ lesson.name }}</h1>

    <h4 class="mb-4">Курс: <a class="text-break link-underline link-underline-opacity-0" href="{{ path('app_course_show', {id: lesson.course.id}) }}">{{ lesson.course.name }}</a></h4>

    <div class="d-flex gap-2 mb-3">
        <a href="{{ path('app_lesson_edit', {id: lesson.id}) }}" class="btn btn-outline-secondary">Редактировать</a>
        {{ include('lesson/_delete_form.html.twig') }}
    </div>

    <div class="text-break border rounded p-3">
        {{ lesson.content }}
    </div>
{% endblock %}
