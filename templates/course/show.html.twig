{% extends 'base.html.twig' %}

{% block title %}{{ course.name }}{% endblock %}

{% block body %}
    <h1 class="text-break">{{ course.name }}</h1>
    <p class="text-break">{{ course.description }}</p>

    <h2>Уроки</h2>
    <ol>
        {% for lesson in course.lessons %}
            <li>
                <a class=" text-break link-underline link-underline-opacity-0 fw-bold"  href="{{ path('app_lesson_show', {id: lesson.id}) }}">{{ lesson.name }}</a>
            </li>
        {% else %}
            <p>Уроков пока нет</p>
        {% endfor %}
    </ol>

    <hr>

    <div class="d-flex gap-2">
        <a href="{{ path('app_course_index') }}" class="btn btn-outline-secondary">К списку курсов</a>
        <a href="{{ path('app_course_edit', {id: course.id}) }}" class="btn btn-secondary">Редактировать</a>
        {{ include('course/_delete_form.html.twig') }}
        <a href="{{ path('app_lesson_new', {course_id: course.id}) }}" class="btn btn-outline-secondary">Добавить урок</a>
    </div>
{% endblock %}
